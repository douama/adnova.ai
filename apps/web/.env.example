# Copy to .env (gitignored) and fill the values.
# All keys MUST start with VITE_ to be exposed to the client bundle.

# Supabase project (eu-west-1 — AdNova's Project)
# Dashboard: https://supabase.com/dashboard/project/jrfxmgxtnftbcxoqzagz
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Worker API base (Phase 5+, when we have the Hono backend)
# Leave empty in Phase 2 — frontend talks directly to Supabase.
VITE_API_BASE_URL=
