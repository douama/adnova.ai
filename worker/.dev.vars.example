# Copy this to .dev.vars (gitignored) for local `wrangler dev`.
# For production: `wrangler secret put <NAME>` (one by one) or `wrangler secret bulk .dev.vars`.

# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# --- Postgres direct (for Drizzle migrations only, not runtime) ---
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-...
REPLICATE_API_KEY=r8_...
HEYGEN_API_KEY=

# --- Encryption (for OAuth tokens in DB) ---
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# --- OAuth platforms (filled during Phase 2) ---
META_APP_ID=
META_APP_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# --- Stripe (Phase 6) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
